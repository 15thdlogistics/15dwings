<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>15D WINGS | VIP Flight Booking v8.0.2</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.cdnfonts.com/css/lexend" rel="stylesheet">
    <link href="https://fonts.cdnfonts.com/css/monument-extended" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>
    <style>
        :root {
            /* PERMANENT DARK THEME AS THE ABSOLUTE DEFAULT */
            --bg-main: #090d16;
            
            /* REDUCED OPACITY BY 20% (from 0.75 to 0.55) FOR INCREDIBLE VIDEO VISIBILITY */
            --glass: rgba(15, 23, 42, 0.55); 
            
            --glass-border: rgba(255, 255, 255, 0.15);
            --glass-border-bottom: rgba(255, 255, 255, 0.10);
            
            /* ADJUSTED INPUTS BY 20% FOR CONTINUOUS DYNAMIC PASS-THROUGH VISIBILITY */
            --input-bg: rgba(15, 23, 42, 0.70);
            --input-border: rgba(255, 255, 255, 0.35);

            --text-main: #f8fafc; /* Crisp Slate 50 */
            --text-soft: #cbd5e1; /* Slate 300 secondary text */
            --accent: #38bdf8;
            --accent-glow: rgba(56, 189, 248, 0.40);
            
            /* ADJUSTED INTERNAL PANELS BY 20% FOR VISUAL COHESION */
            --disclaimer-bg: rgba(15, 23, 42, 0.65);
            --disclaimer-text: #f8fafc;
            --modal-bg: #090d16;
            
            --glow-primary: rgba(56, 189, 248, 0.15);
            --glow-secondary: rgba(37, 99, 235, 0.10);
            
            --overlay-bg: rgba(9, 13, 22, 0.99);
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
            font-family: 'Lexend', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* MONUMENT REGULAR ENFORCEMENT - NEVER BOLDED */
        .monument {
            font-family: 'Monument Extended', sans-serif !important;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            font-weight: 400 !important;
        }

        /* GUARANTEED HIGH-CONTRAST PLACEHOLDERS IN LEXEND SENTENCE CASE */
        ::-webkit-input-placeholder { color: var(--text-soft) !important; font-weight: 500; opacity: 0.85 !important; }
        ::-moz-placeholder { color: var(--text-soft) !important; font-weight: 500; opacity: 0.85 !important; }
        :-ms-input-placeholder { color: var(--text-soft) !important; font-weight: 500; opacity: 0.85 !important; }
        ::placeholder { color: var(--text-soft) !important; font-weight: 500; opacity: 0.85 !important; }

        /* FORCE NATIVE CALENDAR/DATE ICON TO BE CRISP WHITE */
        input[type="datetime-local"]::-webkit-calendar-picker-indicator {
            filter: invert(1) brightness(100%);
            cursor: pointer;
            opacity: 0.9;
        }
        input[type="datetime-local"]::-webkit-calendar-picker-indicator:hover {
            opacity: 1;
        }

        /* CINEMATIC VIDEO BACKGROUND - REVEALED VIVIDLY */
        .bg-video {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            min-width: 100%; min-height: 100%;
            width: auto; height: auto;
            z-index: -2;
            object-fit: cover;
            pointer-events: none;
            opacity: 0.55;
            filter: grayscale(30%) brightness(0.7);
        }

        .bg-swirl {
            position: fixed;
            border-radius: 50%;
            pointer-events: none;
            z-index: -1;
            filter: blur(120px);
            will-change: transform, left, top;
        }
        
        #glow-1 { width: 50vw; height: 50vw; background: var(--glow-primary); transform: translate(-50%, -50%); }
        #glow-2 { width: 60vw; height: 60vw; background: var(--glow-secondary); animation: orb-spin 12s infinite linear; }

        @keyframes orb-spin {
            from { transform: translate(-50%, -50%) rotate(0deg) translateX(10%); }
            to { transform: translate(-50%, -50%) rotate(360deg) translateX(10%); }
        }

        /* REFRACTED GLASS PANELS WITH ROBUST CONTRAST STRUCTURE */
        .glass-panel {
            background: var(--glass);
            backdrop-filter: blur(80px) saturate(180%);
            -webkit-backdrop-filter: blur(80px) saturate(180%);
            border-top: 2.5px solid var(--glass-border);
            border-left: 2.5px solid var(--glass-border);
            border-right: 1.5px solid var(--glass-border-bottom);
            border-bottom: 1.5px solid var(--glass-border-bottom);
            border-radius: 26px;
            box-shadow: 0 40px 80px -10px rgba(0, 0, 0, 0.55), inset 0 2px 4px rgba(255, 255, 255, 0.1);
            transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
        }

        /* HIGH-AFFORDANCE INTERACTIVE FIELDS - SENTENCE CASE SENSITIVE */
        .input-pill {
            background: var(--input-bg);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 2px solid var(--input-border);
            border-radius: 18px;
            padding: 16px 20px;
            color: var(--text-main);
            width: 100%;
            transition: all 0.3s ease;
            font-size: 0.95rem;
            font-weight: 500;
            outline: none;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.15);
        }
        .input-pill:focus { 
            border-color: var(--accent); 
            background: #0f172a; 
            box-shadow: 0 0 0 4px var(--accent-glow), inset 0 2px 4px rgba(0,0,0,0.15); 
        }

        /* THE CHOSEN PRIMARY ACCENT FOR COST */
        .price-text {
            font-size: 3.5rem;
            font-weight: 700;
            color: var(--accent);
            letter-spacing: -0.04em;
            text-shadow: 0 4px 15px var(--accent-glow);
        }

        /* INTERACTION AFFORDANCES FOR SYSTEM CONTROLS */
        .btn-luxury {
            background: #ffffff;
            color: #0f172a;
            border-radius: 20px;
            padding: 20px;
            font-family: 'Monument Extended', sans-serif;
            font-weight: 400;
            font-size: 0.75rem;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            width: 100%;
            border: 2px solid #ffffff;
        }
        .btn-luxury:disabled { opacity: 0.3; filter: grayscale(1); cursor: not-allowed; transform: scale(0.98); }
        .btn-luxury:hover:not(:disabled) { box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5); transform: translateY(-2px); }

        #map { height: 350px; border-radius: 20px; z-index: 10; overflow: hidden; background: #e2e8f0; border: 2.5px solid var(--glass-border); }

        .log-line {
            display: flex; align-items: center; gap: 10px;
            font-size: 0.7rem;
            color: var(--text-soft); margin-bottom: 12px; opacity: 0.9; transition: all 0.5s ease;
            font-weight: 500;
        }
        .log-line.active { color: var(--text-main); opacity: 1; }
        .dot { width: 8px; height: 8px; border-radius: 50%; background: #ffffff; }
        .log-line.active .dot { background: var(--accent); box-shadow: 0 0 10px var(--accent-glow); }

        .suggestion-box {
            position: absolute; top: 105%; left: 0; right: 0;
            background: var(--modal-bg); border-radius: 16px;
            border: 2.5px solid var(--input-border); z-index: 100;
            box-shadow: 0 15px 45px rgba(0,0,0,0.5); display: none;
            max-height: 250px; overflow-y: auto; backdrop-filter: blur(40px);
        }

        .leg-row {
            background: var(--disclaimer-bg);
            padding: 24px;
            border-radius: 20px;
            position: relative;
            margin-bottom: 16px;
            border: 2.5px solid var(--input-border);
        }

        .leg-price-badge {
            font-size: 0.8rem; font-weight: 700; color: var(--text-main);
            background: rgba(255, 255, 255, 0.12); padding: 8px 16px;
            border-radius: 10px; display: inline-block;
            border: 2px solid var(--input-border);
        }

        .disclaimer-box {
            background: var(--disclaimer-bg); border: 2.5px solid var(--glass-border);
            color: var(--disclaimer-text); padding: 2.2rem; border-radius: 26px; line-height: 1.7;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        #processing-overlay {
            position: fixed; inset: 0; background: var(--overlay-bg); z-index: 1000;
            display: none; flex-direction: column; align-items: center; justify-content: center;
            backdrop-filter: blur(60px);
        }

        /* VALIDATION & ERROR STYLES */
        .input-error {
            border-color: #dc2626 !important;
            background: rgba(239, 68, 68, 0.15) !important;
            box-shadow: 0 0 0 4px rgba(220, 38, 38, 0.2) !important;
        }
        .error-msg {
            color: #dc2626;
            font-size: 0.75rem;
            font-weight: 500;
            margin-top: 8px;
            display: none;
            padding-left: 12px;
        }
        .input-error ~ .error-msg { display: block; animation: fade-in 0.3s ease; }

        .btn-error {
            background: linear-gradient(135deg, #dc2626, #991b1b) !important;
            box-shadow: 0 10px 30px rgba(220, 38, 38, 0.4) !important;
            color: white !important;
            animation: shakeBtn 0.4s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
        }

        @keyframes shakeBtn {
            10%, 90% { transform: translate3d(-2px, 0, 0); }
            20%, 80% { transform: translate3d(4px, 0, 0); }
            30%, 50%, 70% { transform: translate3d(-8px, 0, 0); }
            40%, 60% { transform: translate3d(8px, 0, 0); }
        }
        @keyframes fade-in { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }

        /* Success & Modal Contrast Optimization */
        #modal-success { background: var(--modal-bg); }
        #tour-overlay {
            position: fixed; inset: 0; background: rgba(2, 6, 23, 0.96); 
            z-index: 5000; display: none; flex-direction: column; align-items: center; justify-content: center;
            padding: 2rem; text-align: center; backdrop-filter: blur(20px);
        }
        .tour-card {
            max-width: 500px; background: rgba(15, 23, 42, 0.9); 
            backdrop-filter: blur(40px);
            border: 2px solid rgba(255, 255, 255, 0.2);
            padding: 3rem 2.5rem; border-radius: 32px; 
            box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.5);
            color: #ffffff; position: relative; overflow: hidden;
        }
        .step-indicator { font-size: 0.65rem; color: #38bdf8; margin-bottom: 1.5rem; display: block; letter-spacing: 0.2em;}
    </style>
</head>
<body class="p-4 md:p-10">

    <!-- Infinite Looping Video Background -->
    <video id="bg-video" class="bg-video" autoplay loop muted playsinline>
        <source src="https://res.cloudinary.com/dfbweqelf/video/upload/v1777901872/VID-20260428-WA0004_xuyz4u.mp4" type="video/mp4">
    </video>

    <!-- Cursor Following Gradients -->
    <div id="glow-1" class="bg-swirl"></div>
    <div id="glow-2" class="bg-swirl"></div>

    <div id="processing-overlay">
        <div class="text-center space-y-8 max-w-md w-full px-10">
            <div class="price-text text-5xl mb-4 uppercase font-black tracking-wider text-slate-50 filter drop-shadow">Calculating Estimate</div>
            <div class="h-2.5 w-full bg-slate-700 rounded-full overflow-hidden">
                <div id="p-bar" class="h-full bg-white w-0 transition-all duration-700"></div>
            </div>
            <p id="p-step" class="monument text-[0.7rem] text-slate-50 bg-black/95 px-5 py-3 rounded-lg backdrop-blur border-2 border-slate-800">Securing your VIP flight details...</p>
        </div>
    </div>

    <main class="max-w-7xl mx-auto space-y-10 relative z-10">
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div>
                <h1 class="monument text-3xl mb-1 text-slate-50">15D WINGS</h1>
                <p class="text-[0.65rem] tracking-[0.5em] text-slate-50 font-black">EXCLUSIVE PRIVATE JET BOOKING v8.0.2</p>
            </div>
            <div class="flex flex-col items-center">
                <div class="flex gap-4">
                    <button id="export-btn" onclick="handleExportClick()" class="glass-panel px-6 py-3 text-[0.6rem] monument transition-transform active:scale-95 text-slate-50 font-black hover:scale-105">Download Estimate PDF</button>
                    <span class="glass-panel px-6 py-3 text-[0.6rem] monument text-slate-400 font-black cursor-default selection:bg-transparent">VIP PORTAL STANDARD</span>
                </div>
                <span id="export-error-msg" class="error-msg text-center !mt-4 font-bold" style="display:none;">Action required: Please request flight to unlock PDF</span>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <div class="lg:col-span-7 space-y-8">
                <div class="glass-panel p-6 md:p-10 space-y-10">
                    <div>
                        <span class="monument text-[0.7rem] text-slate-50 block mb-6 font-black tracking-widest">/ Executive Details</span>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div class="relative">
                                <label class="block text-slate-100 font-bold tracking-wide text-xs mb-2">Full name</label>
                                <input type="text" id="name" placeholder="Executive name" class="input-pill" oninput="clearError(this)" required>
                                <span class="error-msg">Add the missing details</span>
                            </div>
                            <div class="relative">
                                <label class="block text-slate-100 font-bold tracking-wide text-xs mb-2">Email address</label>
                                <input type="email" id="email" placeholder="executive@domain.com" class="input-pill" oninput="clearError(this)" required>
                                <span class="error-msg">Add the missing details</span>
                            </div>
                            <div class="relative">
                                <label class="block text-slate-100 font-bold tracking-wide text-xs mb-2">Phone number</label>
                                <input type="tel" id="phone" placeholder="+1 (555) 000-0000" class="input-pill" oninput="clearError(this)" required>
                                <span class="error-msg">Add the missing details</span>
                            </div>
                        </div>
                    </div>

                    <div class="pt-10 border-t border-slate-800">
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-6 gap-4">
                            <span class="monument text-[0.7rem] text-slate-50 block font-black tracking-widest">/ Your Travel Route</span>
                            
                            <!-- Trip Type Selector -->
                            <div class="flex items-center gap-2 bg-slate-950 p-1.5 rounded-full border-2 border-slate-800 backdrop-blur-md">
                                <button id="btn-oneway" onclick="setTripType('ONEWAY')" class="flex items-center gap-2 text-[0.6rem] monument text-slate-50 bg-slate-800 shadow-md px-5 py-2.5 rounded-full border border-slate-700 transition-all font-black">✈️ ONE WAY TRIP</button>
                                <button id="btn-round" onclick="setTripType('ROUND')" class="flex items-center gap-2 text-[0.6rem] monument text-slate-300 hover:bg-slate-800/50 px-5 py-2.5 rounded-full border border-transparent transition-all font-black">🔄 ROUND TRIP</button>
                            </div>
                        </div>
                        
                        <div id="legs-container" class="space-y-4"></div>
                        
                        <!-- HIGH ACCESSIBILITY CONTRAST BUTTON -->
                        <button id="add-leg-btn" onclick="addLeg()" class="flex items-center gap-2 text-[0.65rem] monument text-slate-950 bg-white hover:opacity-90 shadow-lg px-6 py-4 rounded-full border-2 border-slate-300 transition-all font-black tracking-widest">
                            [ + Add Another Stop ]
                        </button>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-10 border-t border-slate-800">
                        <div>
                            <span class="monument text-[0.7rem] text-slate-50 block mb-4 font-black tracking-widest">/ Choose Your Jet</span>
                            <select id="ac-class" class="input-pill font-bold" onchange="syncPaxLogic()">
                                <option value="LIGHT">Light Jet | 4-6 Seats (Short Trips)</option>
                                <option value="MID">Midsize Jet | 7-9 Seats (Extended Range)</option>
                                <option value="HEAVY" selected>Heavy Jet | 10-14 Seats (VIP Group)</option>
                                <option value="ULTRA">Ultra/Regional | 15-50 Seats (Corporate)</option>
                            </select>
                            <div id="ac-specs" class="text-xs bg-slate-950/80 border border-slate-800 p-4 rounded-xl mt-4 text-slate-100 italic font-medium backdrop-blur-md leading-relaxed">
                                Loading fleet profile...
                            </div>
                        </div>
                        <div>
                            <span class="monument text-[0.7rem] text-slate-50 block mb-4 font-black tracking-widest">/ Number of Passengers</span>
                            <input type="number" id="pax" value="1" min="1" class="input-pill font-bold text-slate-50" oninput="runAnalysis()">
                            <p id="pax-warning" class="text-xs text-red-400 mt-2 font-bold hidden">Too many passengers for this jet: please upgrade</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-5 space-y-8">
                <div class="glass-panel p-10 text-center relative overflow-hidden">
                    <span class="monument text-[0.65rem] text-slate-50 mb-6 block font-black tracking-widest">Estimated Flight Cost (USD)</span>
                    <div id="price-val" class="price-text">$0</div>
                    <div id="confidence-tag" class="text-[0.55rem] monument text-slate-50 mt-2 uppercase font-black tracking-wider">Subject to final market confirmation</div>
                </div>

                <div class="glass-panel p-6">
                    <div id="map"></div>
                </div>

                <div class="glass-panel p-10">
                    <span class="monument text-[0.65rem] text-slate-50 mb-8 block font-black tracking-widest">Flight Logistics & Status</span>
                    <div id="intel-log" class="space-y-2">
                        <div class="log-line" id="l-dist"><div class="dot"></div> Flight route confirmed</div>
                        <div class="log-line" id="l-min"><div class="dot"></div> Standard flight time applied</div>
                        <div class="log-line" id="l-env"><div class="dot"></div> Jet range is capable</div>
                        <div class="log-line" id="l-intl"><div class="dot"></div> International permits included</div>
                        <div class="log-line" id="l-urg"><div class="dot"></div> Standard 72-hour notice</div>
                    </div>
                </div>

                <div class="disclaimer-box">
                    <span class="monument text-[0.65rem] text-slate-50 mb-4 block font-black tracking-widest border-b-2 border-slate-800 pb-2">Important VIP Flight Advisory</span>
                    <p class="text-xs opacity-95 mb-4 text-slate-100 font-semibold leading-relaxed">
                        <span class="text-slate-50 font-black uppercase block mb-1 text-[0.65rem] tracking-wider">72-Hour Advance Booking:</span>
                        To guarantee the highest standard of service and ensure the jet is perfectly prepared, we require at least 3 days notice. For emergency flights, please chat with our Chief Concierge immediately.
                    </p>
                    <p class="text-xs opacity-95 text-slate-100 font-semibold leading-relaxed">
                        <span class="text-slate-50 font-black uppercase block mb-1 text-[0.65rem] tracking-wider">Pricing Notice:</span>
                        The price shown above is a very close estimate. Your final cost might be slightly less or more depending on exact jet availability when you book.
                    </p>
                </div>
            </div>
        </div>

        <div class="max-w-2xl mx-auto mt-20 mb-10 space-y-5">
            <button id="dispatch-btn" onclick="startDispatch()" class="btn-luxury py-5 text-[0.8rem] font-black tracking-widest uppercase">Request VIP Flight Now</button>
            <a href="https://wa.me/+2349167621703" target="_blank" class="glass-panel w-full block text-center py-5 font-black monument text-[0.7rem] text-slate-50 hover:bg-slate-800/50 transition-colors border-2 border-transparent hover:border-slate-700">
                Chat with Chief Concierge
            </a>
            
            <div class="flex flex-col items-center pt-4">
                <button onclick="toggleSupport()" class="text-xs text-slate-50 hover:opacity-80 transition-opacity flex items-center gap-2 font-semibold">
                    <span class="w-2.5 h-2.5 rounded-full bg-green-500 animate-pulse"></span> 24/7 Executive support
                </button>
                <div id="support-msg" class="text-xs text-slate-50 italic mt-0 opacity-0 h-0 overflow-hidden transition-all duration-500 ease-in-out text-center max-w-sm font-semibold">
                    Our luxury concierge team is working diligently to assist you. Responses are usually within 15 minutes.
                </div>
            </div>
        </div>

        <footer class="text-center pt-10 pb-16 border-t-2 border-slate-800">
            <div class="max-w-2xl mx-auto space-y-4 font-bold">
                <p class="text-[0.7rem] monument text-slate-50">15D Wings | Sky Party LTD (RC 8997727)</p>
                <p class="text-xs text-slate-50 leading-relaxed font-semibold px-4">
                    21 Lugard Avenue, Ikoyi Lagos, Nigeria.
                </p>
                <a href="mailto:ops@15dwings.com.ng" class="text-xs text-slate-50 underline opacity-90 hover:opacity-100 font-medium">ops@15dwings.com.ng</a>
            </div>
        </footer>
    </main>

    <!-- SUCCESS MODAL (OPTIMIZED WITH DOWNLOADS AT THE TOP AND MOBILE SCROLLABLE CAPABILITIES) -->
    <div id="modal-success" class="fixed inset-0 backdrop-blur-2xl z-[2000] hidden flex-col items-center justify-start p-6 text-center overflow-y-auto">
        <div class="max-w-xl space-y-8 my-auto py-10">
            <div class="price-text text-4xl uppercase font-black text-slate-50">Request Successfully Sent</div>
            
            <!-- CONTROLS POSITIONED CONVENIENTLY AT THE TOP FOR SHORTER VIEWPORTS -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center bg-slate-900/40 p-4 rounded-3xl border border-slate-800 backdrop-blur">
                <button onclick="generatePDF()" class="monument text-[0.65rem] px-8 py-4 bg-white text-slate-950 rounded-full hover:scale-105 transition-transform shadow-lg font-black tracking-wider border-2 border-transparent">Download Cost Estimate (PDF)</button>
                <button onclick="location.reload()" class="monument text-[0.65rem] px-8 py-4 text-slate-200 border-2 border-slate-700 rounded-full hover:bg-slate-800 transition-colors font-black tracking-wider">Book Another Flight</button>
            </div>

            <p id="ref-id" class="monument text-sm text-slate-50 font-black tracking-widest">YOUR FLIGHT REQUEST IS PROCESSING</p>
            <div class="glass-panel p-8 md:p-10 text-xs text-slate-50 leading-relaxed text-left font-semibold">
                <b class="text-slate-50 monument text-[0.7rem] block mb-2 underline font-black tracking-widest">NEXT STEPS:</b>
                We have safely received your details. Please check your email immediately at <span id="conf-email" class="text-slate-50 font-bold underline"></span> for your official flight estimate and next steps from our team.<br><br>
                <div class="bg-slate-900/60 p-6 rounded-xl border-2 border-slate-800 text-center shadow-lg">
                    <span class="block text-xs text-slate-200 mb-2 font-bold">Your dashboard password</span>
                    
                    <div class="flex items-center justify-center gap-3">
                        <span class="font-bold text-3xl text-slate-50 tracking-widest block py-2" id="ref-id-inline"></span>
                        <button id="copy-id-btn" onclick="copyMissionId()" class="text-xs bg-slate-800 hover:bg-slate-700 px-3 py-1.5 rounded-lg border border-slate-600 transition-colors font-bold text-slate-300">Copy</button>
                    </div>

                    <p class="text-xs mt-3 mb-5 text-slate-200 opacity-100 leading-relaxed font-semibold">Use this Request ID to log into the VIP dashboard to unlock your final quote and engineered outcomes.</p>
                    
                    <!-- DIRECT INTEGRATION BUTTON FOR VIP PORTAL -->
                    <button onclick="openVipPortal()" class="w-full py-4 bg-[#38bdf8] hover:bg-[#0284c7] text-slate-950 font-bold text-xs rounded-xl transition-all shadow-[0_0_20px_rgba(56,189,248,0.3)] border-2 border-[#38bdf8]">Log Into VIP Portal Now</button>
                </div>
