        </div>
    </div>

    <!-- 3-STEP TOUR OVERLAY -->
    <div id="tour-overlay">
        <div class="tour-card animate-fade-in">
            <span class="step-indicator monument font-black" id="tour-step-num">Step 1 of 3</span>
            <h2 class="monument text-xl mb-4 text-white font-black" id="tour-title">Instant Pricing</h2>
            <p class="text-sm text-white opacity-95 mb-8 leading-relaxed font-semibold" id="tour-desc">
                No waiting for brokers. See your estimated flight cost instantly across Nigeria and the world. Please note that the final cost includes a 5% certainty cost for guaranteeing certainty.
            </p>
            <button onclick="nextTourStep()" class="btn-luxury py-3 px-10 w-auto inline-block border border-white/20">Next Step</button>
        </div>
    </div>

    <script>
        const INTAKE_WORKER_URL = 'https://intake.15d.name.ng';
        const GAS_URL = 'https://script.google.com/macros/s/AKfycbwhhmVYLdMHeqBvb5mETjWhBJdPi3rMdoHsWBTxdEOWRy_uchTV43f63fU6Mi3_ncrf/exec';
        const SUPABASE_URL = 'YOUR_SUPABASE_URL';
        const SUPABASE_ANON_KEY = 'YOUR_SUPABASE_ANON_KEY';

        const AIRCRAFT = {
            LIGHT: { speed: 700, rate: 2800, minHrs: 1.0, label: "Light Jet", range: 2500, maxPax: 6, models: "Phenom 300, Citation CJ4, Hawker 400XP", image: "https://images.unsplash.com/photo-1540962351504-03099e0a754b?auto=format&fit=crop&w=800&q=80" },
            MID:   { speed: 780, rate: 4000, minHrs: 1.0, label: "Midsize Jet", range: 3800, maxPax: 9, models: "Hawker 800/900XP, Learjet 60XR, Praetor 500", image: "https://res.cloudinary.com/dw9m06rgf/image/upload/v1778682411/Website-midsize-JEt-1024x499_exojji.jpg" },
            HEAVY: { speed: 850, rate: 6000, minHrs: 1.0, label: "Heavy Jet", range: 6500, maxPax: 14, models: "Challenger 604/605, Legacy 600/650, Falcon 900", image: "https://res.cloudinary.com/dw9m06rgf/image/upload/v1778682756/65bd26a6a22e0c57f5eb0fc8_65134bb72c32636b787adb9d_large-private-jet_icgtng.webp" },
            ULTRA: { speed: 920, rate: 9000, minHrs: 1.0, label: "Ultra/Regional", range: 12500, maxPax: 50, models: "ERJ-135/145, Global 6000/7500, G550/G650", image: "https://res.cloudinary.com/dw9m06rgf/image/upload/v1778682889/Bombardier_Global_6000_LX-NST_Exterior_4_1600x1200_fnstut.jpg" }
        };

        let DB = {}, map, routeLines = [], currentTargetPrice = 0, currentTargetPriceHigh = 0, displayedPrice = 0, displayedPriceHigh = 0;
        let activeLegsData = [], serverMissionID = null;
        let isRoundTrip = false;

        // EDGE API ROUTING VARIABLES
        let searchTimeout = null;
        const WORKER_URL = "https://airfields.15d.name.ng";

        // Force a physical locked 72-Hour ISO Minimum Limit
        function getMinDateTime() {
            const tzoffset = (new Date()).getTimezoneOffset() * 60000;
            const minTime = new Date(Date.now() + (72 * 3600000) - tzoffset);
            return minTime.toISOString().slice(0, 16);
        }

        // Continually updates and enforces constraints on Date fields physically
        function enforceDatePickerLimits() {
            const minStr = getMinDateTime();
            document.querySelectorAll('.date-in').forEach(input => {
                input.setAttribute('min', minStr);
                // Physical control filter on entry
                input.addEventListener('input', function() {
                    if (this.value && this.value < minStr) {
                        this.value = minStr;
                        alert("For operational perfection, flights require 72 hours notice. The system has automatically reset the departure to our earliest available slot.");
                    }
                });
            });
        }

        async function loadDB() {
            console.log("15D Wings: Migrated to Edge API Data Routing");
        }

        function initMap() {
            map = L.map('map', { zoomControl: false, attributionControl: false }).setView([9.08, 7.39], 5);
            // Switched back to Light Mode tiles for clean dynamic contrast
            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(map);
        }

        // Left empty as theme switcher is deprecated, keeping structural signature verbatim
        function toggleTheme() {}
        
        // Fix for toggling Support message
        function toggleSupport() {
            const msg = document.getElementById('support-msg');
            if (msg.classList.contains('opacity-0')) {
                msg.classList.remove('opacity-0', 'h-0');
                msg.classList.add('opacity-100', 'h-auto', 'mt-4');
            } else {
                msg.classList.add('opacity-0', 'h-0');
                msg.classList.remove('opacity-100', 'h-auto', 'mt-4');
            }
        }

        function clearError(el) {
            el.classList.remove('input-error');
            if (el.classList.contains('airport-in')) suggest(el);
        }

        function setTripType(type) {
            isRoundTrip = (type === 'ROUND');
            
            // Toggle Active Button Styles
            const activeClass = "flex items-center gap-2 text-[0.6rem] monument text-slate-50 bg-slate-800 shadow-md px-5 py-2.5 rounded-full border border-slate-700 transition-all font-black";
            const inactiveClass = "flex items-center gap-2 text-[0.6rem] monument text-slate-300 hover:bg-slate-800/50 px-5 py-2.5 rounded-full border border-transparent transition-all font-black";

            document.getElementById('btn-oneway').className = isRoundTrip ? inactiveClass : activeClass;
            document.getElementById('btn-round').className = isRoundTrip ? activeClass : inactiveClass;

            // If switching to Round Trip, simplify routing to just one standard leg row (A to B)
            if (isRoundTrip) {
                const legs = document.querySelectorAll('.leg-row');
                for(let i = 1; i < legs.length; i++) legs[i].remove();
                document.getElementById('add-leg-btn').style.display = 'none';
            } else {
                document.getElementById('add-leg-btn').style.display = 'flex';
            }

            // Show/Hide the return date inputs across existing legs
            document.querySelectorAll('.return-date-block').forEach(el => {
                el.style.display = isRoundTrip ? 'block' : 'none';
            });

            runAnalysis();
        }

        function syncPaxLogic() {
            const cls = document.getElementById('ac-class').value;
            const spec = AIRCRAFT[cls];
            document.getElementById('ac-specs').innerHTML = `
                <div class="w-full h-32 rounded-xl mb-3 overflow-hidden relative shadow-inner">
                    <img src="${spec.image}" alt="${spec.label}" class="w-full h-full object-cover opacity-90 hover:opacity-100 transition-opacity duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                    <span class="absolute bottom-3 left-4 text-white font-bold tracking-widest text-[0.6rem] uppercase drop-shadow-md">${spec.label}</span>
                </div>
                <span class="block font-black text-slate-50 uppercase mb-1">Fleet Profile: ${spec.models}</span>
                <span class="block text-slate-300 font-medium">Range: ~${spec.range}km | Speed: ${spec.speed}km/h | Capacity: Up to ${spec.maxPax} Seats</span>
            `;
            runAnalysis();
        }

        function addLeg() {
            const c = document.getElementById('legs-container');
            const legId = Date.now();
            const d = document.createElement('div');
            d.className = "leg-row";
            d.id = `leg-${legId}`;
            
            const isFirstLeg = c.children.length === 0;
            const delBtnHtml = isFirstLeg ? '' : `<button onclick="removeLeg('${legId}')" class="text-[0.55rem] monument text-slate-50 hover:bg-red-500/10 px-4 py-2.5 rounded-full border-2 border-slate-50 transition-colors ml-4 uppercase font-black">Delete Stop</button>`;

            d.innerHTML = `
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
                    <div class="relative">
                        <span class="text-[0.6rem] uppercase monument text-slate-50 mb-2 block font-black tracking-widest">From where</span>
                        <input type="text" placeholder="LOS - Murtala Muhammed Int'l" class="w-full bg-slate-950/70 border-2 border-slate-700 text-slate-50 placeholder-slate-400 rounded-xl p-3 focus:outline-none focus:border-slate-100 transition-all uppercase airport-in font-bold" oninput="clearError(this)" required>
                        <div class="suggestion-box"></div>
                        <span class="error-msg font-bold">Add the missing details</span>
                    </div>
                    <div class="relative">
                        <span class="text-[0.6rem] uppercase monument text-slate-50 mb-2 block font-black tracking-widest">To where</span>
                        <input type="text" placeholder="ABV - Nnamdi Azikiwe Int'l" class="w-full bg-slate-950/70 border-2 border-slate-700 text-slate-50 placeholder-slate-400 rounded-xl p-3 focus:outline-none focus:border-slate-100 transition-all uppercase airport-in font-bold" oninput="clearError(this)" required>
                        <div class="suggestion-box"></div>
                        <span class="error-msg font-bold">Add the missing details</span>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5 items-start">
                    <div class="relative w-full">
                        <span class="text-[0.6rem] uppercase monument text-slate-50 mb-2 block font-black tracking-widest">Flight Date and Time</span>
                        <input type="datetime-local" class="w-full bg-slate-950/70 border-2 border-slate-700 text-slate-50 rounded-xl p-3 focus:outline-none focus:border-slate-100 transition-all date-in forward-date font-bold" onchange="clearError(this); runAnalysis()" required>
                        <span class="error-msg font-bold">Add the missing details</span>
                    </div>
                    <div class="relative w-full return-date-block" style="display: ${isRoundTrip ? 'block' : 'none'};">
                        <span class="text-[0.6rem] uppercase monument text-slate-50 mb-2 block font-black tracking-widest">Return Date and Time</span>
                        <input type="datetime-local" class="w-full bg-slate-950/70 border-2 border-slate-700 text-slate-50 rounded-xl p-3 focus:outline-none focus:border-slate-100 transition-all date-in return-date font-bold" onchange="clearError(this); runAnalysis()">
                        <span class="error-msg font-bold">Add the missing details</span>
                    </div>
                </div>
                <div class="flex justify-between items-center mt-5 ${!isFirstLeg ? 'border-t-2 border-slate-800 pt-5' : ''}">
                    <span class="leg-price-badge font-bold" id="badge-${legId}">$0.00</span>
                    ${delBtnHtml}
                </div>
            `;
            c.appendChild(d);
            enforceDatePickerLimits();
        }

        // Keep removeLeg standard
        function removeLeg(id) {
            if(document.querySelectorAll('.leg-row').length > 1) {
                document.getElementById(`leg-${id}`).remove();
                runAnalysis();
            }
        }

        async function suggest(el) {
            const v = el.value.trim().toUpperCase();
            const box = el.nextElementSibling;
            
            if(v.length < 2) { 
                box.innerHTML = '';
                box.style.display = 'none'; 
                return; 
            }

            // Enterprise UI/UX: Indicate loading state for the executive
            box.innerHTML = '<div class="p-4 text-xs font-bold text-slate-400 animate-pulse">Securing airspace data...</div>';
            box.style.display = 'block';

            // Debounce the input to prevent spamming the edge worker while typing
            clearTimeout(searchTimeout);
            
            searchTimeout = setTimeout(async () => {
                try {
                    const response = await fetch(`${WORKER_URL}/?q=${encodeURIComponent(v)}`);
                    if (!response.ok) throw new Error("API Failure");
                    
                    const results = await response.json();
                    
                    // Critical: Cache the results into our global DB object. 
                    // This ensures when runAnalysis() calculates the haversine distance, the lat/lon is available.
                    Object.assign(DB, results);
                    
                    box.innerHTML = '';
                    const keys = Object.keys(results);

                    if (keys.length > 0) {
                        keys.forEach(k => {
                            const d = results[k];
                            const i = document.createElement('div');
                            i.className = "p-4 hover:bg-slate-800 hover:text-blue-400 cursor-pointer text-xs border-b border-slate-800 font-semibold text-slate-100";
                            i.innerHTML = `<b class="text-blue-400">${k}</b> — ${d.name} (${d.city}, ${d.country})`;
                            
                            // Interaction binding
                            i.onclick = () => { 
                                el.value = `${k} | ${d.name}`; 
                                el.dataset.code = k; 
                                el.dataset.fullName = d.name;
                                el.dataset.country = d.country;
                                box.style.display = 'none'; 
                                runAnalysis(); 
                            };
                            box.appendChild(i);
                        });
                    } else {
                        box.innerHTML = '<div class="p-4 text-xs font-bold text-red-400">No classified airfields found</div>';
                    }
                } catch (error) {
                    console.error("Flight systems mapping error:", error);
                    box.innerHTML = '<div class="p-4 text-xs font-bold text-red-500">Radar offline. Retrying...</div>';
                }
            }, 300); // 300ms debounce
        }

        function runAnalysis() {
            const cls = document.getElementById('ac-class').value;
            const spec = AIRCRAFT[cls];
            const paxCount = parseInt(document.getElementById('pax').value) || 0;
            const warning = document.getElementById('pax-warning');
            const dispatchBtn = document.getElementById('dispatch-btn');
            
            let total = 0, allPoints = [], intl = false, urg = false, minHrs = false;
            let isVolatile = false;
            
            if (paxCount > spec.maxPax) {
                warning.classList.remove('hidden');
                dispatchBtn.disabled = true;
                currentTargetPrice = 0;
                animatePrice();
                document.querySelectorAll('.leg-price-badge').forEach(b => b.innerText = '$0.00');
                return;
            } else {
                warning.classList.add('hidden');
                dispatchBtn.disabled = false;
            }

            routeLines.forEach(l => map.removeLayer(l));
            routeLines = [];
            activeLegsData = [];

            document.querySelectorAll('.leg-row').forEach(l => {
                const inputs = l.querySelectorAll('.airport-in');
                const oCode = inputs[0].dataset.code, dCode = inputs[1].dataset.code;
                const fDateIn = l.querySelector('.forward-date');
                const rDateIn = l.querySelector('.return-date');
                const badge = l.querySelector('.leg-price-badge');

                if(oCode && dCode && DB[oCode] && DB[dCode]) {
                    const rad = Math.PI/180;
                    const dLat = (DB[dCode].lat - DB[oCode].lat) * rad;
                    const dLon = (DB[dCode].lon - DB[oCode].lon) * rad;
                    const a = Math.sin(dLat/2)**2 + Math.cos(DB[oCode].lat*rad)*Math.cos(DB[dCode].lat*rad)*Math.sin(dLon/2)**2;
                    const dist = 6371 * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
                    
                    const actualHours = dist/spec.speed;
                    const hours = Math.max(actualHours, spec.minHrs);
                    if(actualHours < spec.minHrs) minHrs = true;

                    let baseCost = hours * spec.rate;
                    let adjustedBase = baseCost * (1 + (paxCount * 0.01));
                    
                    const isIntl = inputs[0].dataset.country !== inputs[1].dataset.country;
                    const logisticsFee = isIntl ? 3500 : 1500;
                    if(isIntl) intl = true;

                    let legTotal = adjustedBase + logisticsFee;
                    
                    // Add Forward Leg
                    total += legTotal;
                    activeLegsData.push({ 
                        from: oCode, to: dCode, cost: legTotal, 
                        date: fDateIn.value ? new Date(fDateIn.value).toLocaleDateString() : 'TBD',
                        time: fDateIn.value ? new Date(fDateIn.value).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : 'TBD',
                        fromFull: inputs[0].dataset.fullName, toFull: inputs[1].dataset.fullName 
                    });
                    allPoints.push([DB[oCode].lat, DB[oCode].lon], [DB[dCode].lat, DB[dCode].lon]);
                    routeLines.push(L.polyline([[DB[oCode].lat, DB[oCode].lon], [DB[dCode].lat, DB[dCode].lon]], { color: "#38bdf8", weight: 3, dashArray: '5, 10' }).addTo(map));

                    // Add Return Leg if active and valid
                    if (isRoundTrip && rDateIn && rDateIn.value) {
                        total += legTotal; 
                        activeLegsData.push({ 
                            from: dCode, to: oCode, cost: legTotal, 
                            date: new Date(rDateIn.value).toLocaleDateString(),
                            time: new Date(rDateIn.value).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
                            fromFull: inputs[1].dataset.fullName, toFull: inputs[0].dataset.fullName 
                        });
                        allPoints.push([DB[dCode].lat, DB[dCode].lon], [DB[oCode].lat, DB[oCode].lon]);
                        routeLines.push(L.polyline([[DB[dCode].lat, DB[dCode].lon], [DB[oCode].lat, DB[oCode].lon]], { color: "#0284c7", weight: 3, dashArray: '5, 10' }).addTo(map));
                    }
                    
                    badge.innerText = `$${Math.round(isRoundTrip && rDateIn.value ? legTotal * 2 : legTotal).toLocaleString()}`;

                    if(fDateIn.value) {
                        const diff = (new Date(fDateIn.value) - new Date()) / 3600000;
                        if(diff > 0 && diff < 72) { urg = true; isVolatile = true; }
                    }
                }
            });

            currentTargetPrice = total;
            currentTargetPriceHigh = total > 0 ? total + 4566 : 0; 
            animatePrice();
            
            if(allPoints.length) map.fitBounds(L.latLngBounds(allPoints), { padding: [50, 50] });

            document.querySelectorAll('.log-line').forEach(l => l.classList.remove('active'));
            if(total > 0) document.getElementById('l-dist').classList.add('active');
            if(minHrs) document.getElementById('l-min').classList.add('active');
            if(intl) document.getElementById('l-intl').classList.add('active');
            
            const logUrg = document.getElementById('l-urg');
            if(isVolatile) {
                logUrg.classList.add('active');
                logUrg.innerHTML = `<div class="dot"></div> NOTICE: EMERGENCY FLIGHT REQUIRES CONCIERGE`;
                logUrg.style.color = '#dc2626';
            } else if (urg) {
                logUrg.classList.add('active');
                logUrg.innerHTML = `<div class="dot"></div> Standard 72-hour notice applied`;
                logUrg.style.color = '';
            } else {
                logUrg.innerHTML = `<div class="dot"></div> Standard 72-hour notice applied`;
                logUrg.style.color = '';
            }
        }

        function animatePrice() {
            let animating = false;
            if (Math.abs(currentTargetPrice - displayedPrice) > 1) {
                displayedPrice += (currentTargetPrice - displayedPrice) * 0.1;
                animating = true;
            } else {
                displayedPrice = currentTargetPrice;
            }

            if (Math.abs(currentTargetPriceHigh - displayedPriceHigh) > 1) {
                displayedPriceHigh += (currentTargetPriceHigh - displayedPriceHigh) * 0.1;
                animating = true;
            } else {
                displayedPriceHigh = currentTargetPriceHigh;
            }

            const priceEl = document.getElementById('price-val');
            if (displayedPrice > 0) {
                priceEl.innerHTML = `<span class="text-[2rem] md:text-[2.2rem] font-bold">$${Math.round(displayedPrice).toLocaleString()}</span> <span class="text-[2rem] mx-1">-</span> <span class="text-[2rem] md:text-[2.2rem] font-bold">$${Math.round(displayedPriceHigh).toLocaleString()}</span>`;
            } else {
                priceEl.innerText = '$0';
            }

            if (animating) requestAnimationFrame(animatePrice);
        }

        let mouseX = window.innerWidth / 2, mouseY = window.innerHeight / 2;
        let glow1X = mouseX, glow1Y = mouseY;
        let glow2X = mouseX, glow2Y = mouseY;

        document.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });

        function animateSwirl() {
            glow1X += (mouseX - glow1X) * 0.08; glow1Y += (mouseY - glow1Y) * 0.08;
            glow2X += (mouseX - glow2X) * 0.03; glow2Y += (mouseY - glow2Y) * 0.03;

            const g1 = document.getElementById('glow-1'), g2 = document.getElementById('glow-2');
            if(g1) { g1.style.left = glow1X + 'px'; g1.style.top = glow1Y + 'px'; }
            if(g2) { g2.style.left = glow2X + 'px'; g2.style.top = glow2Y + 'px'; }
            requestAnimationFrame(animateSwirl);
        }

        async function startDispatch() {
            let isValid = true;
            
            const nameInput = document.getElementById("name");
            const emailInput = document.getElementById("email");
            const phoneInput = document.getElementById("phone");
            
            function markInvalid(el) { el.classList.add('input-error'); isValid = false; }

            if(!nameInput.value) markInvalid(nameInput);
            if(!emailInput.value || !emailInput.value.includes('@')) markInvalid(emailInput);
            if(!phoneInput.value) markInvalid(phoneInput);
            
            document.querySelectorAll('.leg-row').forEach(l => {
                const inputs = l.querySelectorAll('.airport-in');
                const fDateIn = l.querySelector('.forward-date');
                const rDateIn = l.querySelector('.return-date');
                
                inputs.forEach(inp => { if(!inp.dataset.code) markInvalid(inp); });
                
                if(!fDateIn.value) { 
                    markInvalid(fDateIn); 
                } else {
                    const diff = (new Date(fDateIn.value) - new Date()) / 3600000;
                    if(diff < 71.9) { 
                        markInvalid(fDateIn);
                        alert("For operational perfection, flights require 72 hours notice. Please select a valid date or contact our Concierge directly on WhatsApp for an emergency jet booking.");
                    }
                }

                if (isRoundTrip) {
                    if(!rDateIn.value) markInvalid(rDateIn);
                    else if (fDateIn.value && new Date(rDateIn.value) <= new Date(fDateIn.value)) {
                        markInvalid(rDateIn);
                        alert("Return date and time must be after the forward flight date and time.");
                    }
                }
            });

            if(!isValid || currentTargetPrice === 0) {
                const btn = document.getElementById('dispatch-btn');
                btn.classList.add('btn-error');
                setTimeout(() => btn.classList.remove('btn-error'), 400);
                return;
            }
            
            const name = nameInput.value, email = emailInput.value, phone = phoneInput.value;
            
            const ov = document.getElementById('processing-overlay'), bar = document.getElementById('p-bar'), step = document.getElementById('p-step');
            ov.style.display = 'flex';
            
            const requestID = `15D-${Math.random().toString(36).substring(2, 7).toUpperCase()}`;
            const payload = { 
                name, email, phone,
                request_id: requestID, ref_id: requestID,
                total_estimate: Math.round(currentTargetPrice),
                estimate_lower: Math.round(currentTargetPrice),
                estimate_upper: Math.round(currentTargetPriceHigh),
                aircraft: AIRCRAFT[document.getElementById('ac-class').value].label,
                legs: activeLegsData,
                timestamp: new Date().toISOString()
            };

            const steps = ["Validating Routing", "Preparing Executive Estimate", "Sending Details to Concierge"];
            for(let i=0; i<steps.length; i++) {
                step.innerText = steps[i]; bar.style.width = `${(i+1)*33}%`;
                await new Promise(r => setTimeout(r, 600));
            }

            try {
                await fetch(INTAKE_WORKER_URL, { method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify(payload) });
                fetch(GAS_URL, { method: "POST", mode: "no-cors", body: JSON.stringify(payload) });
                
                if(SUPABASE_URL !== 'YOUR_SUPABASE_URL') {
                    fetch(`${SUPABASE_URL}/rest/v1/missions`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}`, 'Prefer': 'return=minimal' },
                        body: JSON.stringify(payload)
                    }).catch(e => console.error("Supabase sync failed silently.", e));
                }
            } catch (e) {}

            serverMissionID = requestID;
            document.getElementById('export-btn').classList.remove('opacity-50');
            document.getElementById('conf-email').innerText = email;
            document.getElementById('ref-id').innerText = `REQUEST ID: ${serverMissionID}`;
            document.getElementById('ref-id-inline').innerText = serverMissionID;
            document.getElementById('modal-success').style.display = 'flex';
            ov.style.display = 'none';

            // AUTOMATICALLY TRIGGER DOWNLOAD
            generatePDF();
        }

        // I-FRAME SAFE COPY FUNCTION
        function copyMissionId() {
            if (!serverMissionID) return;
            const textArea = document.createElement("textarea");
            textArea.value = serverMissionID;
            textArea.style.top = "0";
            textArea.style.left = "0";
            textArea.style.position = "fixed";
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();
            try {
                document.execCommand('copy');
                const btn = document.getElementById('copy-id-btn');
                const orig = btn.innerText;
                btn.innerText = "COPIED!";
                btn.classList.add("text-green-400", "border-green-400");
                setTimeout(() => {
                    btn.innerText = orig;
                    btn.classList.remove("text-green-400", "border-green-400");
                }, 2000);
            } catch (err) {
                console.error('Copy failed', err);
            }
            document.body.removeChild(textArea);
        }

        // DIRECT VIP PORTAL INTEGRATION
        function openVipPortal() {
            if (!serverMissionID) return;
            window.open(`https://portal.15dwings.com.ng/?ref_id=${serverMissionID}`, '_blank');
        }

