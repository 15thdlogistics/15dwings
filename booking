            doc.restoreGraphicsState();

            doc.setFillColor(0, 0, 0); doc.rect(0, 0, pageWidth, 20, 'F');
            doc.setTextColor(255); doc.setFontSize(10);
            doc.text(`VIP FLIGHT ESTIMATE: ${serverMissionID}`, 15, 13);
            doc.text(`ISSUED: ${issuanceDate}`, pageWidth - 15, 13, { align: 'right' });

            doc.setTextColor(0); doc.setFontSize(24); doc.text("15D WINGS", 15, 40);
            doc.setFontSize(9); doc.text("Premium Private Jet Services", 15, 47);
            
            doc.setFontSize(10); doc.text(`EXECUTIVE: ${clientName.toUpperCase()}`, 15, 60);
            doc.setFontSize(8); doc.setTextColor(100);
            doc.text(`EMAIL: ${clientEmail}`, 15, 65); doc.text(`PHONE: ${clientPhone}`, 15, 70);
            doc.setTextColor(0, 0, 0); doc.setFont(undefined, 'bold');
            doc.text(`AIRCRAFT: ${aircraftLabel.toUpperCase()}`, 15, 75);
            doc.setFont(undefined, 'normal'); doc.setTextColor(100);
            doc.text("21 Lugard Avenue, Ikoyi Lagos, Nigeria", 15, 80);

            doc.autoTable({
                startY: 90,
                head: [['Flight Route', 'Date', 'Time', 'Estimated Cost (USD)']],
                body: activeLegsData.map(l => [`${l.from} > ${l.to}`, l.date, l.time, `$${Math.round(l.cost).toLocaleString()}`]),
                headStyles: { fillColor: [0, 0, 0] }, theme: 'striped'
            });

            const finalY = doc.lastAutoTable.finalY;
            doc.setFontSize(14); doc.setTextColor(24, 119, 242);
            doc.text(`ESTIMATED RANGE: $${Math.round(currentTargetPrice).toLocaleString()} - $${Math.round(currentTargetPriceHigh).toLocaleString()}`, 15, finalY + 15);

            doc.setFontSize(9); doc.setTextColor(0); doc.setFont(undefined, 'bold');
            doc.text('"Architects of Certainty in Private Aviation"', pageWidth / 2, finalY + 32, { align: 'center' });
            
            doc.setFont(undefined, 'italic'); doc.setFontSize(8); doc.setTextColor(80);
            doc.text('"Certainty is not Hope, it is Engineered Readiness"', pageWidth / 2, finalY + 40, { align: 'center' });
            
            doc.setFont(undefined, 'normal'); doc.setFontSize(8); doc.setTextColor(100);
            const encouragement = [
                "This document provides a highly accurate market estimate for your requested route.",
                "Please use your Request ID to log into the VIP portal at portal.15dwings.com.ng",
                "to access your final quote and engineered outcomes.",
                "Our Concierge team will contact you shortly to confirm and secure your booking."
            ];
            doc.text(encouragement, 15, finalY + 52);

            doc.setFontSize(7); doc.setTextColor(150);
            doc.text("24/7 SUPPORT: ops@15dwings.com.ng", 15, pageHeight - 15);
            doc.text("15dwings.com.ng | 15D Wings | Sky Party LTD (RC 8997727)", pageWidth - 15, pageHeight - 15, { align: 'right' });
            doc.text("TIN: 33695910-0001", pageWidth - 15, pageHeight - 11, { align: 'right' });

            doc.save(`15D-WINGS-EXECUTIVE-ESTIMATE-${serverMissionID}.pdf`);
        }

        function handleExportClick() { if(serverMissionID) generatePDF(); else document.getElementById('export-error-msg').style.display = 'block'; }

        let tourStep = 0;
        const tourData = [
            { title: "Instant VIP Estimates", desc: "No waiting for brokers. See your estimated flight cost instantly across Nigeria and the world. Please note that the final cost includes a 5% certainty cost for guaranteeing certainty.", target: "price-val" },
            { title: "Jet Selection & Protocol", desc: "Your price updates automatically based on the jet selected. Please note we strictly require a 72-hour notice to perfectly prepare your jet for departure.", target: "ac-class" },
            { title: "Dashboard Passcode", desc: "Upon submitting, your Flight Request ID (e.g., 15D-XXXXX) serves as your password key to log into portal.15dwings.com.ng. There, you can directly select premium Experiential Flights.", target: "dispatch-btn" }
        ];

        function checkFirstVisit() {
            if (!sessionStorage.getItem('15d_tour_v2_completed')) {
                document.getElementById('tour-overlay').style.display = 'flex';
                updateTourUI();
            }
        }

        updateTourUI = function() {
            document.getElementById('tour-step-num').innerText = `Step ${tourStep + 1} of ${tourData.length}`;
            document.getElementById('tour-title').innerText = tourData[tourStep].title;
            document.getElementById('tour-desc').innerText = tourData[tourStep].desc;
        }

        function nextTourStep() {
            tourStep++;
            if (tourStep >= tourData.length) {
                document.getElementById('tour-overlay').style.display = 'none';
                sessionStorage.setItem('15d_tour_v2_completed', 'true');
                return;
            }
            updateTourUI();
        }

        window.addEventListener('DOMContentLoaded', () => { checkFirstVisit(); });
        window.onload = () => { loadDB(); addLeg(); initMap(); syncPaxLogic(); animateSwirl(); };
    </script>
